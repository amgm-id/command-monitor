# Copy this to .env and fill in your values
SECRET_KEY=generate-a-long-random-string-here-minimum-32-chars

# Database (override defaults if needed)
DATABASE_URL=postgresql://serveragent:serveragent123@localhost:5432/serveragent_db

# Redis
REDIS_URL=redis://localhost:6379

# CORS origins (comma-separated JSON array)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Debug mode (never true in production)
DEBUG=false
